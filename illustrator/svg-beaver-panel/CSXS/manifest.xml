                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>SVG Beaver</Menu>
                    <Geometry>
                        <Size>
                            <Width>340</Width>
                            <Height>900</Height>
                        </Size>
                        <MinSize>
                            <Width>300</Width>
                            <Height>420</Height>
