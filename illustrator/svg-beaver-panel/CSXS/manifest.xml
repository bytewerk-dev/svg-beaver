<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="6.0"
    ExtensionBundleId="com.bytewerk.svgbeaver"
    ExtensionBundleVersion="1.0.0"
    ExtensionBundleName="SVG Beaver"
